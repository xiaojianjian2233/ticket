# ===== ticket-hub 后端配置（密钥走环境变量，勿提交真实值）=====

# 应用
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 数据库 PostgreSQL (pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ticket_hub

# JWT
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=28800

# webhook 鉴权
WEBHOOK_ACCESS_TOKEN=change-me

# 飞书 SSO
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SSO_REDIRECT_URI=
# 飞书机器人 webhook（多个用逗号分隔；可按场景分群）
FEISHU_BOT_WEBHOOKS=
FEISHU_BOT_WEBHOOK_SLA_MANUAL=
FEISHU_BOT_WEBHOOK_SLA_RD=
FEISHU_BOT_WEBHOOK_SYSTEM=

# KSM
KSM_BASE_URL=https://ierp.kingdee.com
KSM_APP_ID=
KSM_APP_SECRET=
KSM_TENANT_ID=
KSM_ACCOUNT_ID=
KSM_USER=

# 智齿
ZHICHI_BASE_URL=https://www.soboten.com
ZHICHI_APPID=
ZHICHI_APP_KEY=

# ask agent (open-api-channel)
AGENT_BASE_URL=
AGENT_APPID=
AGENT_APP_KEY=

# 硅基流动 embedding
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# LLM (Claude 主 / DeepSeek 降级)
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Linear
LINEAR_API_TOKEN=
LINEAR_TEAM=CNPRD
# 转 Linear 统一指派：配人名→所有 issue 都给此人；留空→正常逻辑(不强制指派)
LINEAR_FORCE_ASSIGNEE=李志坚

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=ticket-hub
MINIO_PUBLIC_BASE=https://fpy-jfsv.kingdee.com:8864

# 业务阈值（可配）
FAQ_HIT_THRESHOLD=0.8
INFO_DEDUP_THRESHOLD=0.85
HUB_DEDUP_THRESHOLD=0.80
FAQ_DEDUP_THRESHOLD=0.85
SLA_MANUAL_HOURS=48
SLA_RD_HOURS=48
OBSERVE_DAYS=14
QUEUE_BACKLOG_N=100
QUEUE_OLDEST_M=30
DEFAULT_DEV_OWNER=待人工分配

# 去AI化：列入的 skill 跳过 LLM 返回规则默认(逗号分隔，空=全AI)
SKILL_NO_AI=

# KSM 处理人(lock/handle/supply 的 account/工号；登录账号见 KSM_USER)
KSM_HANDLER_NAME=李志坚
KSM_HANDLER_NUMBER=
